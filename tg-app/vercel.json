{
  "rewrites": [
    { "source": "/m/:slug", "destination": "/api/m/:slug" },
    { "source": "/",        "destination": "/index.html"  }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
